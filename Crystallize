local function af_getAllModels()
	local results = {}
	

	for _, obj in ipairs(workspace:GetChildren()) do
		if obj:IsA("Model") and obj.Name == "Plant Box" then
			table.insert(results, obj)
		end
	end
	

	local dep = workspace:FindFirstChild("Deployables")
	if dep then
		for _, obj in ipairs(dep:GetChildren()) do
			if obj:IsA("Model") and obj.Name == "Plant Box" then
				table.insert(results, obj)
			end
		end
	end
	

	local map = workspace:FindFirstChild("Map")
	if map then
		for _, obj in ipairs(map:GetDescendants()) do
			if obj:IsA("Model") and obj.Name == "Plant Box" then
				table.insert(results, obj)
			end
		end
	end
	

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("Model") and obj.Name == "Plant Box" then
			
			local found = false
			for _, r in ipairs(results) do
				if r == obj then found=true; break end
			end
			if not found then table.insert(results, obj) end
		end
	end
	
	return results
end


local function af_boxIsEmpty(obj)
	
	local hasPlant = obj:GetAttribute("HasPlant") or obj:GetAttribute("Planted") or obj:GetAttribute("Seeded")
	if hasPlant then return false end
	
	
	for _, child in ipairs(obj:GetChildren()) do
		if child:IsA("Model") then return false end
		local n = child.Name:lower()
		if n:find("seed") or n:find("plant") or n:find("crop") or n:find("fruit") or n:find("sprout") then
			return false
		end
	end
	
	
	local state = obj:GetAttribute("PlantState") or obj:GetAttribute("State") or obj:GetAttribute("GrowthStage")
	if state and state ~= 0 and state ~= "Empty" and state ~= "" then return false end
	
	return true
end

local function af_getPlantBoxes(range)
	local out = {}
	if not root then return out end
	
	local allBoxes = af_getAllModels()
	
	for _, obj in ipairs(allBoxes) do
		local eid = obj:GetAttribute("EntityID")
		local ppart = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
		
		if eid and ppart then
			local dist = (ppart.Position - root.Position).Magnitude
			if dist <= range then
				local isEmpty = af_boxIsEmpty(obj)
				table.insert(out, {
					entityid = eid,
					deployable = obj,
					ppart = ppart,
					dist = dist,
					isEmpty = isEmpty,
				})
			end
		end
	end
	
	table.sort(out, function(a,b) return a.dist < b.dist end)
	return out
end


local function af_getFruitBushes(range, fruitname)
	local out = {}
	if not root then return out end
	
	
	local searchIn = {workspace}
	local foldersToCheck = {"Resources","Plants","Fruits","Environment","Map","World"}
	for _, fname in ipairs(foldersToCheck) do
		local f = workspace:FindFirstChild(fname)
		if f then table.insert(searchIn, f) end
	end
	
	local seen = {}
	for _, container in ipairs(searchIn) do
		local list = container == workspace and workspace:GetChildren() or container:GetDescendants()
		for _, model in ipairs(list) do
			if not seen[model] and model:IsA("Model") then
				seen[model] = true
				
				local modelNameLower = model.Name:lower()
				local fruitLower = fruitname:lower()
				if modelNameLower:find(fruitLower, 1, true) then
					local ppart = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
					if ppart then
						local dist = (ppart.Position - root.Position).Magnitude
						if dist <= range then
							local eid = model:GetAttribute("EntityID")
							if eid then
								table.insert(out, {
									entityid = eid,
									model = model,
									ppart = ppart,
									dist = dist,
								})
							end
						end
					end
				end
			end
		end
	end
	
	table.sort(out, function(a,b) return a.dist < b.dist end)
	return out
end


local function af_tweenCancel()
	if af_activeTween then
		pcall(function() af_activeTween:Cancel() end)
		af_activeTween = nil
	end
end

local function af_tweenTo(targetCF)
	af_tweenCancel()
	if not root then return end
	local dist = (root.Position - targetCF.Position).Magnitude
	if dist < 3 then return end 
	local speed = 25 
	local duration = dist / speed
	local tw = tspmo:Create(
		root,
		TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.In),
		{ CFrame = targetCF }
	)
	tw:Play()
	af_activeTween = tw
end


local function af_startTweenLoop()
	if af_tweenThread then task.cancel(af_tweenThread) end
	af_tweenThread = task.spawn(function()
		while AF.tweenToBoxes or AF.tweenToFruits do
			if root then
				local target = nil
				
				if AF.tweenToFruits then
					local bushes = af_getFruitBushes(AF.tweenRange, AF.selectedFruit)
					if #bushes > 0 then
						target = bushes[1].ppart.CFrame + Vector3.new(0, 4, 0)
					end
				end
				
				if not target and AF.tweenToBoxes then
					local boxes = af_getPlantBoxes(AF.tweenRange)
					for _, box in ipairs(boxes) do
						if box.isEmpty then
							target = box.ppart.CFrame + Vector3.new(0, 4, 0)
							break
						end
					end
				end
				
				if target then
					af_tweenTo(target)
				end
			end
			task.wait(0.5) 
		end
		af_tweenCancel()
	end)
end

local function af_stopTweenLoop()
	if af_tweenThread then task.cancel(af_tweenThread); af_tweenThread=nil end
	af_tweenCancel()
end


local function af_placeGrid(gridsize)
	if not char or not root then return 0 end
	gridsize = gridsize or AF.gs
	local baseY = root.Position.Y - 3
	local ox, oz = root.Position.X, root.Position.Z
	local half = (gridsize-1)/2
	local count = 0
	for x=0,gridsize-1 do
		for z=0,gridsize-1 do
			placeOne(Vector3.new(ox+(x-half)*AF.sp, baseY, oz+(z-half)*AF.sp))
			count += 1
			af_placedTotal += 1
			task.wait(AF.placeDelay)
		end
	end
	return count
end


local af_pFolder = nil
local af_pTiles = {}
local af_pBuiltGs = 0
local af_pBuiltSp = 0
local af_pActive = false
local af_pThread = nil

local function af_gpos(gs, sp)
	if not root then return {} end
	local h = (gs-1)/2; local out = {}
	for x=0,gs-1 do
		for z=0,gs-1 do
			out[#out+1] = Vector3.new(
				root.Position.X+(x-h)*sp,
				root.Position.Y-3,
				root.Position.Z+(z-h)*sp
			)
		end
	end
	return out
end

local function af_clearPrev()
	if af_pFolder and af_pFolder.Parent then af_pFolder:Destroy() end
	af_pFolder=nil; af_pTiles={}; af_pBuiltGs=0; af_pBuiltSp=0
end

local function af_buildPrev(gs, sp)
	af_clearPrev()
	local f = Instance.new("Folder"); f.Name="__PBPrev__"; f.Parent=workspace; af_pFolder=f
	local ts = math.max(sp-0.3, 1)
	for i=1,gs*gs do
		local p = Instance.new("Part")
		p.Size=Vector3.new(ts,0.12,ts); p.Anchored=true; p.CanCollide=false
		p.CastShadow=false; p.Material=Enum.Material.Neon
		p.Color=Color3.fromRGB(50,220,100); p.Transparency=0.35; p.Parent=f
		
		local sel=Instance.new("SelectionBox")
		sel.Color3=Color3.fromRGB(80,255,130); sel.LineThickness=0.05
		sel.SurfaceTransparency=0.7; sel.SurfaceColor3=Color3.fromRGB(50,220,100)
		sel.Adornee=p; sel.Parent=p
		
		local bb=Instance.new("BillboardGui")
		bb.Size=UDim2.new(0,34,0,22); bb.StudsOffset=Vector3.new(0,0.5,0)
		bb.AlwaysOnTop=true; bb.Adornee=p; bb.Parent=p
		
		local lbl=Instance.new("TextLabel")
		lbl.Size=UDim2.new(1,0,1,0); lbl.BackgroundTransparency=1
		lbl.Text=tostring(i); lbl.TextColor3=Color3.new(1,1,1)
		lbl.TextScaled=true; lbl.Font=Enum.Font.GothamBold
		lbl.TextStrokeTransparency=0.3; lbl.Parent=bb
		
		af_pTiles[i] = p
	end
	af_pBuiltGs=gs; af_pBuiltSp=sp
end

local function af_updatePrev(gs, sp, yr)
	local pos = af_gpos(gs, sp)
	local rot = CFrame.Angles(0, math.rad(yr), 0)
	for i,p in ipairs(af_pTiles) do
		if pos[i] and p.Parent then p.CFrame = CFrame.new(pos[i])*rot end
	end
end

local function af_startPrev()
	if af_pThread then task.cancel(af_pThread) end
	af_pThread = task.spawn(function()
		af_buildPrev(AF.gs, AF.sp)
		while af_pActive do
			if AF.gs~=af_pBuiltGs or AF.sp~=af_pBuiltSp then af_buildPrev(AF.gs, AF.sp) end
			af_updatePrev(AF.gs, AF.sp, AF.yr)
			task.wait(af_curFPS >= 50 and 0.07 or 0.15)
		end
		af_clearPrev()
	end)
end

local function af_stopPrev()
	af_pActive=false
	if af_pThread then task.cancel(af_pThread); af_pThread=nil end
	af_clearPrev()
end


