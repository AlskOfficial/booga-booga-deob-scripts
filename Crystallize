local function writeF32LE(buf, offset, value)
	local sign, exp, mant
	if value ~= value then sign=0; exp=255; mant=1
	elseif value == math.huge then sign=0; exp=255; mant=0
	elseif value == -math.huge then sign=1; exp=255; mant=0
	elseif value == 0 then sign=0; exp=0; mant=0
	else
		sign = value < 0 and 1 or 0; value = math.abs(value)
		exp = math.floor(math.log(value, 2))
		mant = math.floor((value/2^exp-1)*0x800000+0.5)
		exp = exp + 127
		if mant >= 0x800000 then mant=0; exp+=1 end
		if exp >= 255 then exp=255; mant=0
		elseif exp <= 0 then mant=math.floor(value/2^(-126)*0x800000+0.5); exp=0 end
	end
	local int = sign*0x80000000 + exp*0x800000 + mant
	buffer.writeu8(buf,offset,  bit32.band(int,0xFF))
	buffer.writeu8(buf,offset+1,bit32.band(bit32.rshift(int,8),0xFF))
	buffer.writeu8(buf,offset+2,bit32.band(bit32.rshift(int,16),0xFF))
	buffer.writeu8(buf,offset+3,bit32.band(bit32.rshift(int,24),0xFF))
end

local function writeU32LE(buf, offset, value)
	buffer.writeu8(buf,offset,  bit32.band(value,0xFF))
	buffer.writeu8(buf,offset+1,bit32.band(bit32.rshift(value,8),0xFF))
	buffer.writeu8(buf,offset+2,bit32.band(bit32.rshift(value,16),0xFF))
	buffer.writeu8(buf,offset+3,bit32.band(bit32.rshift(value,24),0xFF))
end

local function writeU16LE(buf, offset, value)
	buffer.writeu8(buf,offset,  bit32.band(value,0xFF))
	buffer.writeu8(buf,offset+1,bit32.band(bit32.rshift(value,8),0xFF))
end


local function buildPlacePacket(pos)
	local buf = buffer.create(31)
	buffer.writeu8(buf,0,0x00); buffer.writeu8(buf,1,0xE0)
	buffer.writeu8(buf,2,0x09); buffer.writeu8(buf,3,0x00)
	local name = "Plant Box"
	for i=1,#name do buffer.writeu8(buf,3+i,string.byte(name,i)) end
	writeF32LE(buf,13,pos.X); writeF32LE(buf,17,pos.Y); writeF32LE(buf,21,pos.Z)
	for i=25,30 do buffer.writeu8(buf,i,0x00) end
	return buf
end

local function buildPlantPacket(entityID, itemID)
	local buf=buffer.create(8)
	buffer.writeu8(buf,0,0x00); buffer.writeu8(buf,1,0x68)
	writeU32LE(buf,2,entityID); writeU16LE(buf,6,itemID)
	return buf
end

local function buildHarvestPacket(entityID)
	local buf=buffer.create(6)
	buffer.writeu8(buf,0,0x00); buffer.writeu8(buf,1,0xE6)
	writeU32LE(buf,2,entityID)
	return buf
end

local function placeOne(pos)   pcall(function() RE_ByteNet:FireServer(buildPlacePacket(pos)) end) end
