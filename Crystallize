	ESPSection:Toggle({ Title="Show Friendly", Value=false, Callback=function(s) showFriendly=s; RefreshESP() end })
	ESPSection:Toggle({ Title="Tribe ESP",     Value=false, Callback=function(s) showTribe=s;    RefreshESP() end })
end

