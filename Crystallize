local espEnabled    = false
local showFriendly  = false
local showTribe     = false
local ENEMY_COLOR   = Color3.fromRGB(255,0,0)
local FRIENDLY_COLOR = Color3.fromRGB(0,255,0)
local playerConnections = {}

do
	local function IsFriendly(p)
		if not p.Team or not Players.LocalPlayer.Team then return false end
		if p.Team.Name=="NoTribe" or Players.LocalPlayer.Team.Name=="NoTribe" then return false end
		return p.Team == Players.LocalPlayer.Team
	end
	local function ShouldShow(p)
		if p==Players.LocalPlayer then return false end
		return IsFriendly(p) and showFriendly or espEnabled
	end
	local function GetColor(p) return IsFriendly(p) and FRIENDLY_COLOR or ENEMY_COLOR end
	local function BuildText(p)
		local tribePart = ""
		if showTribe and p.Team then
			local tc = p.TeamColor.Color
			local r,g,b = math.floor(tc.R*255),math.floor(tc.G*255),math.floor(tc.B*255)
			tribePart = ' <font color="rgb('..r..","..g..","..b..')">[' .. p.Team.Name .. "]</font>"
		end
		if espEnabled then return p.Name .. tribePart
		elseif showTribe then return tribePart ~= "" and tribePart or "" end
		return ""
	end
	local function CreateBillboard(ch, p)
		local head = ch:FindFirstChild("Head"); if not head then return end
		local billboard = ch:FindFirstChild("ESP_Billboard")
		if not billboard then
			billboard = Instance.new("BillboardGui"); billboard.Name="ESP_Billboard"; billboard.Adornee=head
			billboard.Size=UDim2.new(0,220,0,40); billboard.StudsOffset=Vector3.new(0,3.7,0)
			billboard.AlwaysOnTop=true; billboard.Enabled=false; billboard.Parent=ch
			local text = Instance.new("TextLabel"); text.Name="ESP_Text"; text.Size=UDim2.new(1,0,1,0)
			text.BackgroundTransparency=1; text.RichText=true; text.Text=""
			text.TextTransparency=1; text.Font=Enum.Font.GothamBold; text.TextSize=10
			text.TextStrokeTransparency=0.5; text.TextStrokeColor3=Color3.new(0,0,0); text.Parent=billboard
		end
		local textLabel = billboard:FindFirstChild("ESP_Text"); if not textLabel then billboard:Destroy(); return end
		local text = BuildText(p); textLabel.Text=""
		if text ~= "" then
			billboard.Enabled=true; textLabel.TextTransparency=0
			if string.find(text,"<font") then textLabel.RichText=true; textLabel.Text=text
			else textLabel.RichText=false; textLabel.Text=text; textLabel.TextColor3=GetColor(p) end
		else billboard.Enabled=false; textLabel.TextTransparency=1 end
	end
	local function CreateHighlight(ch, p)
		local hl = ch:FindFirstChild("ESP_Highlight")
		if not hl then hl=Instance.new("Highlight"); hl.Name="ESP_Highlight"; hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop; hl.Parent=ch end
		if ShouldShow(p) then hl.Enabled=true; hl.FillColor=GetColor(p); hl.OutlineColor=GetColor(p); hl.Adornee=ch
		else hl.Enabled=false end
	end
	local function UpdateESP(ch)
		local p = Players:GetPlayerFromCharacter(ch); if not p or p==Players.LocalPlayer then return end
		CreateBillboard(ch,p); CreateHighlight(ch,p)
	end
	local function RemoveESP(ch)
		if not ch then return end
		local h=ch:FindFirstChild("ESP_Highlight"); if h then h:Destroy() end
		local b=ch:FindFirstChild("ESP_Billboard"); if b then b:Destroy() end
	end
	local function SetupPlayer(p)
		if p==Players.LocalPlayer or playerConnections[p] then return end
		local conns = {}
		table.insert(conns, p.CharacterAdded:Connect(function(ch) task.wait(0.1); UpdateESP(ch) end))
		table.insert(conns, p.CharacterRemoving:Connect(function(ch) RemoveESP(ch) end))
		playerConnections[p] = conns
		if p.Character then task.defer(UpdateESP, p.Character) end
	end
	local function CleanupPlayer(p)
		if playerConnections[p] then for _,c in ipairs(playerConnections[p]) do c:Disconnect() end; playerConnections[p]=nil end
		if p.Character then RemoveESP(p.Character) end
	end
	local function RefreshESP()
		for _, p in ipairs(Players:GetPlayers()) do if p~=Players.LocalPlayer and p.Character then UpdateESP(p.Character) end end
	end
	Players.PlayerAdded:Connect(SetupPlayer)
	Players.PlayerRemoving:Connect(CleanupPlayer)
	for _, p in ipairs(Players:GetPlayers()) do SetupPlayer(p) end

	local ESPSection = Tabfour:Section({ Title="ESP", Icon="eye" })
