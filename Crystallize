	local AllowedRarities = {"God","Emerald","Leaf","Void","PinkDiamond","Magnetite","Crystal","Adurite","Steel","Iron","Hide","Diamond"}
	local RarityLookup   = {}
	for _, v in ipairs(AllowedRarities) do RarityLookup[v:lower()] = v end
	local keywords = {"chestplate","chest","greaves","legs","helmet","hood","halo","shirt","pants","shroud"}

	local function GetArmorData(ch)
		local found = {}; local colors = {}
		for _, item in ipairs(ch:GetChildren()) do
			local nameLower = item.Name:lower()
			for _, keyword in ipairs(keywords) do
				if string.find(nameLower, keyword) then
					local split = string.split(item.Name, " "); local firstWord = split[1]
					local rarity = RarityLookup[firstWord:lower()]
					if rarity and not found[rarity] then
						found[rarity] = true
						local handle = item:FindFirstChild("Handle")
						if handle and handle:IsA("BasePart") then table.insert(colors, {name=rarity, color=handle.Color})
						else table.insert(colors, {name=rarity, color=Color3.fromRGB(0,255,0)}) end
					end; break
				end
			end
		end
		if #colors == 0 then return "No Armour", Color3.fromRGB(255,255,255), false end
		if #colors > 1 then
			local rich = ""
			for i, data in ipairs(colors) do
				local c=data.color; local r,g,b=math.floor(c.R*255),math.floor(c.G*255),math.floor(c.B*255)
				rich = rich .. '<font color="rgb('..r..","..g..","..b..')">' .. data.name .. "</font>"
				if i < #colors then rich = rich .. ", " end
			end
			return rich, Color3.new(1,1,1), true
		else return colors[1].name, colors[1].color, false end
	end

	local function CreateOrUpdateESP(ch)
		if not ch:FindFirstChild("HumanoidRootPart") then return end
		local billboard = ch:FindFirstChild("ARMOUR_TAG")
		if not billboard then
			billboard = Instance.new("BillboardGui"); billboard.Name="ARMOUR_TAG"
			billboard.Adornee=ch.HumanoidRootPart; billboard.Size=UDim2.new(0,200,0,30)
			billboard.StudsOffset=Vector3.new(0,-9,0); billboard.AlwaysOnTop=true; billboard.Parent=ch
			local text = Instance.new("TextLabel"); text.Name="Text"
			text.Size=UDim2.new(1,0,1,0); text.BackgroundTransparency=1; text.RichText=true
			text.TextStrokeTransparency=0.5; text.TextStrokeColor3=Color3.new(0,0,0)
			text.Font=Enum.Font.GothamBold; text.TextSize=9.5; text.Parent=billboard
		end
		local textLabel=billboard:FindFirstChild("Text"); if not textLabel then return end
		local textValue,color,isRich = GetArmorData(ch)
		textLabel.RichText=isRich; textLabel.Text=textValue; textLabel.TextColor3=color
	end

	local function StartUpdatingPlayer(p)
		if updateThreads[p] then return end
		updateThreads[p] = task.spawn(function()
			while armourEnabled and p and p.Parent do
				if p.Character then CreateOrUpdateESP(p.Character) end; task.wait(0.2)
			end
		end)
	end
	local function StopAll()
		armourEnabled=false; for p in pairs(updateThreads) do updateThreads[p]=nil end
		for _, p in pairs(Players:GetPlayers()) do
			if p.Character and p.Character:FindFirstChild("ARMOUR_TAG") then p.Character.ARMOUR_TAG:Destroy() end
		end
	end

	local ESPSection2 = Tabfour:Section({ Title="Armour", Icon="shield" })
	ESPSection2:Toggle({ Title="Armour ESP", Value=false, Callback=function(s)
		armourEnabled=s
		if s then for _, p in pairs(Players:GetPlayers()) do if p~=Players.LocalPlayer then StartUpdatingPlayer(p) end end
		else StopAll() end
	end })
	Players.PlayerAdded:Connect(function(p) if armourEnabled and p~=Players.LocalPlayer then StartUpdatingPlayer(p) end end)
end

