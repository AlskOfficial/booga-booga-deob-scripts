local pickupCount = 0
local lastReset   = tick()

task.spawn(function()
	while true do
		task.wait(0.20 + math.random() * 0.10)

		if not pickupActive or not Packets then continue end

		local now = tick()
		if now - lastReset >= 1 then
			pickupCount = 0
			lastReset = now
		end

		if pickupCount >= maxPickupCount then continue end

		local char = Player.Character
		local root = char and char:FindFirstChild("HumanoidRootPart")
		if not root then continue end

		local folder = getFolder()
		if not folder then continue end

		local charPos = root.Position
		local candidates = {}

		for _, item in ipairs(folder:GetChildren()) do
			if pickupCount + #candidates >= maxPickupCount then break end
			local id = item:GetAttribute("EntityID")
			if not id then continue end
			local pos = getPos(item)
			if not pos then continue end
			local dist = (charPos - pos).Magnitude
			local key = item.Name:lower():match("^%s*(.-)%s*$")
			if dist <= pickupRange and selectedItems[key] then
				table.insert(candidates, { id = id, dist = dist })
			end
		end

		table.sort(candidates, function(a, b) return a.dist < b.dist end)

		for _, entry in ipairs(candidates) do
			if pickupCount >= maxPickupCount then break end
			local ok = pcall(function() Packets.Pickup.send(entry.id) end)
			if ok then pickupCount += 1 end
			task.wait(0.03 + math.random() * 0.02)
		end
	end
end)















