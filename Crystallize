do
	local ah_enabled=false; local ah_players=true; local ah_resources=false
	local ah_range=20; local ah_delay=0.05; local ah_thread=nil

	local function buildSwingPacket(hitPos, origin)
		local buf=buffer.create(30)
		buffer.writeu8(buf,0,0x00); buffer.writeu8(buf,1,0x13)
		buffer.writeu8(buf,2,0x00); buffer.writeu8(buf,3,0x00)
		writeF32LE(buf,4,hitPos.X); writeF32LE(buf,8,hitPos.Y); writeF32LE(buf,12,hitPos.Z)
		buffer.writeu8(buf,16,0x00); buffer.writeu8(buf,17,0x00)
		writeF32LE(buf,18,origin.X); writeF32LE(buf,22,origin.Y); writeF32LE(buf,26,origin.Z)
		return buf
	end

	local function getNearestEnemy()
		local best,bd=nil,ah_range
		for _, p in ipairs(Players:GetPlayers()) do
			if p~=plr and p.Character then
				local pr=p.Character:FindFirstChild("HumanoidRootPart")
				local ph=p.Character:FindFirstChild("Humanoid")
				if pr and ph and ph.Health>0 then
					local d=(pr.Position-root.Position).Magnitude
					if d<bd then best=pr; bd=d end
				end
			end
		end
		return best
	end

	local function getNearestResource()
		local best,bd=nil,ah_range
		local res=workspace:FindFirstChild("Resources")
		if not res then return nil end
		for _, obj in ipairs(res:GetChildren()) do
			local pp = obj:IsA("BasePart") and obj
				or (obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")))
			if pp then
				local d=(pp.Position-root.Position).Magnitude
				if d<bd then best=pp; bd=d end
			end
		end
		return best
	end

	local function startAH()
		if ah_thread then task.cancel(ah_thread) end
		ah_thread=task.spawn(function()
			while ah_enabled do
				if root then
					local t=nil
					if ah_players then t=getNearestEnemy() end
					if not t and ah_resources then t=getNearestResource() end
					if t then
						pcall(function() RE_ByteNet:FireServer(buildSwingPacket(t.Position,root.Position)) end)
					end
				end
				task.wait(ah_delay)
			end
		end)
	end

	HitSection:Toggle({ Title="Hit Players",   Value=false, Callback=function(s) ah_players=s end })
	HitSection:Toggle({ Title="Hit Resources", Value=false, Callback=function(s) ah_resources=s end })
	HitSection:Slider({ Title="Range (studs)", Value={Min=5,Max=60,Default=20},               Callback=function(v) ah_range=v end })
	HitSection:Slider({ Title="Delay (s)",     Value={Min=0.01,Max=1,Default=0.05},Step=0.01, Callback=function(v) ah_delay=v end })
	HitSection:Toggle({ Title="Enable Auto Hit", Value=false, Callback=function(s)
		ah_enabled=s
		if s then startAH()
		else if ah_thread then task.cancel(ah_thread); ah_thread=nil end end
	end })

	plr.CharacterAdded:Connect(function(c)
		char=c
		root=c:WaitForChild("HumanoidRootPart")
		hum=c:WaitForChild("Humanoid")
		af_tweenCancel() 
		if ah_enabled then startAH() end
	end)
end











