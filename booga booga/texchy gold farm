local function getClosestChest()
    local hrp = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild('HumanoidRootPart')
    if not hrp then return nil end
    if (hrp.Position - Vector3.new(938, -2, -1407)).Magnitude > 5 then return nil end
    local closest, dist = nil, math.huge
    for _, v in ipairs(workspace.Deployables:GetChildren()) do
        if v:IsA('Model') and v.Name == 'Chest' then
            local pp = v.PrimaryPart or v:FindFirstChildWhichIsA('BasePart')
            if pp then
                local d = (hrp.Position - pp.Position).Magnitude
                if d < dist then
                    closest = v
                    dist = d
                end
            end
        end
    end
    return closest
end

