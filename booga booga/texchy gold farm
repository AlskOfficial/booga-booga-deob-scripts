local function breakGoldNodes()
    local char = game.Players.LocalPlayer.Character
    local hrp = char and char:FindFirstChild('HumanoidRootPart')
    if not hrp then return end
    local resources = workspace.Resources:GetChildren()
    local closest = nil
    local minDist = math.huge
    for _, res in ipairs(resources) do
        local part = res:FindFirstChildWhichIsA('BasePart')
        if part then
            local dist = (part.Position - hrp.Position).Magnitude
            if dist < minDist then
                minDist = dist
                closest = res
            end
        end
    end
    if closest then
        local parts = {}
        for _, p in ipairs(closest:GetChildren()) do
            if p:IsA('BasePart') then
                table.insert(parts, p)
            end
        end
        if #parts > 0 then
            u1.SwingTool.send({parts})
        end
    end
end

local function breakGoldNodesV2()
    local char = game.Players.LocalPlayer.Character
    local hrp = char and char:FindFirstChild('HumanoidRootPart')
    if not hrp then return end
    local goldNodes = {}
    local function scan(model)
        for _, child in ipairs(model:GetChildren()) do
            if child.Name == 'Gold Node' then
                local part = child:FindFirstChildWhichIsA('BasePart')
                if part then
                    table.insert(goldNodes, {
                        goldNode = child,
                        distance = (part.Position - hrp.Position).Magnitude
                    })
                end
            end
            scan(child)
        end
    end
    scan(workspace)
    table.sort(goldNodes, function(a, b) return a.distance < b.distance end)
    if #goldNodes > 0 then
        local node = goldNodes[1].goldNode
        local parts = {}
        for _, p in ipairs(node:GetChildren()) do
            if p:IsA('BasePart') then
                table.insert(parts, p)
            end
        end
        if #parts > 0 then
            u1.SwingTool.send({parts})
        end
    end
end

